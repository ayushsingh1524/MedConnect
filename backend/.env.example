# ==============================================================================
# MedConnect AI - Environment Configuration Example
# ==============================================================================
# INSTRUCTIONS:
# 1. Copy this file to '.env' (in the backend directory).
# 2. Update the values to match your local or production environment.
# 3. NEVER commit your actual '.env' file to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# Application Settings
# ------------------------------------------------------------------------------
# The name of the application.
APP_NAME="MedConnect AI Backend"

# Environment type (development, staging, production)
APP_ENV="development"

# Set to True to enable FastAPI debug mode and tracebacks.
# SECURITY WARNING: Must be False in production!
DEBUG=True

# Log level for application logging (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL="INFO"

# ------------------------------------------------------------------------------
# Database Settings
# ------------------------------------------------------------------------------
# Connection string for the database.
# For local development with SQLite, use sqlite+aiosqlite:///./crm.db
# For production, use PostgreSQL, e.g., postgresql+asyncpg://user:pass@host:port/dbname
DATABASE_URL="sqlite+aiosqlite:///./crm.db"

# ------------------------------------------------------------------------------
# AI Provider Configuration
# ------------------------------------------------------------------------------
# Groq API key for powering the LangGraph agent (gemma2-9b-it).
# Get your API key from: https://console.groq.com/
GROQ_API_KEY="your_groq_api_key_here"

# ------------------------------------------------------------------------------
# Security & Authentication
# ------------------------------------------------------------------------------
# Secret key used for cryptographic signing (e.g., JWT tokens).
# Generate a secure key using: `openssl rand -hex 32`
SECRET_KEY="your_super_secret_development_key_do_not_use_in_production"

# JWT token expiration time in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=1440 # 24 hours

# JWT signing algorithm.
ALGORITHM="HS256"

# ------------------------------------------------------------------------------
# CORS Configuration
# ------------------------------------------------------------------------------
# The URL where your frontend is hosted.
FRONTEND_URL="http://localhost:5173"

# Comma-separated list of allowed origins for CORS.
# In development, usually just the local frontend URL.
# In production, set to your actual domain(s).
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
